{
    "Project Name": "Employee Management System",
    "Project Type": "Human Resource Management",
    "Entities": [
        "Employee",
        "Admin",
        "Report"
    ],
    "Roles": [
        "Admin"
    ],
    "Features": [
        "Create Employee",
        "Update Employee",
        "Generate Report"
    ],
    "API Endpoints": [
        {
            "Endpoint": "/employees",
            "Method": "POST",
            "Description": "Create Employee"
        },
        {
            "Endpoint": "/employees/{id}",
            "Method": "PUT",
            "Description": "Update Employee"
        },
        {
            "Endpoint": "/reports",
            "Method": "GET",
            "Description": "Generate Report"
        }
    ]
}